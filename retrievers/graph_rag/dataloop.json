{
  "name": "graph-rag",
  "displayName": "Graph RAG",
  "version": "0.0.3",
  "description": "Knowledge graph construction, retrieval, and visualization for RAG pipelines.",
  "attributes": {
    "Provider": "Dataloop",
    "Category": "Application",
    "Application Type": "Pipeline Node",
    "Deployed By": "Dataloop",
    "Media Type": [
      "Text"
    ]
  },
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/retrieval-apps.git",
    "gitTag": "0.0.3"
  },
  "components": {
    "modules": [
      {
        "name": "graph-rag-module",
        "entryPoint": "retrievers/graph_rag/graph_rag.py",
        "className": "ServiceRunner",
        "functions": [
          {
            "name": "add_chunk_to_graph",
            "description": "Incrementally add a chunk (prompt item or JSON) to the dataset knowledge graph. Extracts entities and relationships and merges them into the graph.",
            "input": [
              {
                "type": "Item",
                "name": "item"
              },
              {
                "type": "Boolean",
                "name": "store_text"
              }
            ],
            "output": [
              {
                "type": "Item",
                "name": "item"
              }
            ]
          },
          {
            "name": "query_graph",
            "description": "Query the knowledge graph with Cypher-like structured filters (entity_name, relationship, target_name) or natural-language keyword extraction. Adds retrieved context to the prompt item.",
            "input": [
              {
                "type": "Item",
                "name": "item"
              },
              {
                "type": "Dataset",
                "name": "dataset"
              },
              {
                "type": "String",
                "name": "entity_name"
              },
              {
                "type": "String",
                "name": "relationship"
              },
              {
                "type": "String",
                "name": "target_name"
              },
              {
                "type": "Integer",
                "name": "hops"
              }
            ],
            "output": [
              {
                "type": "Item",
                "name": "item"
              }
            ]
          }
        ]
      }
    ],
    "services": [
      {
        "name": "graph-rag-service",
        "moduleName": "graph-rag-module",
        "runtime": {
          "podType": "regular-s",
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/graph-rag:0.0.12",
          "concurrency": 1,
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 1
          }
        }
      }
    ],
    "pipelineNodes": [
      {
        "name": "add-chunk-to-graph",
        "invoke": {
          "type": "function",
          "namespace": "graph-rag-service.graph-rag-module.add_chunk_to_graph"
          },
        "categories": ["graph-rag"],
        "displayName": "Add Chunk to Graph",
        "description": "Add a chunk to the graph.",
        "scope": "project",
        "configuration": {
          "fields": [
            {
              "name": "name",
              "title": "Node Name",
              "props": {
                "title": true,
                "type": "string",
                "default": "add-chunk-to-graph",
                "required": true,
                "placeholder": "Insert node name"
              },
              "rules": [
                {
                  "type": "required",
                  "effect": "error"
                }
              ],
              "widget": "dl-input"
            },
            {
              "name": "store_text",
              "title": "store text",
              "description": "Whether to store the text of the chunk in the graph.",
              "props": {
                "type": "boolean",
                "title": true,
                "default": false,
                "placeholder": "Enter true to store the text of the chunk in the graph"
              },
              "widget": "dl-checkbox"
            }
          ]
        }
      },
      {
        "name": "query-graph",
        "invoke": {
          "type": "function",
          "namespace": "graph-rag-service.graph-rag-module.query_graph"
        },
        "categories": ["graph-rag"],
        "displayName": "Query Graph",
        "description": "Query the graph for relevant chunks.",
        "scope": "project",
        "configuration": {
          "fields": [
            {
              "name": "name",
              "title": "Node Name",
              "props": {
                "title": true,
                "type": "string",
                "default": "query-graph",
                "required": true,
                "placeholder": "Insert node name"
              },
              "rules": [
                {
                  "type": "required",
                  "effect": "error"
                }
              ],
              "widget": "dl-input"
            },
            {
              "name": "hops",
              "title": "hops",
              "description": "The number of hops to search the graph.",
              "props": {
                "type": "number",
                "title": true,
                "default": 2,
                "placeholder": "Enter the number of hops"
              },
              "widget": "dl-input"
            }
          ]
        }
      }
    ]
  }
}
